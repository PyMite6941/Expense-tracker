# Copy to .env and fill in values before deploying

# Shared with backend/ — both must use the same value
JWT_SECRET=replace-with-a-long-random-string

# From Polar.sh dashboard → Webhooks → Secret
POLAR_WEBHOOK_SECRET=replace-with-polar-webhook-secret

# Gmail app password (Settings → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
